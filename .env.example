# Copy to .env and fill in values: cp .env.example .env
# python-dotenv loads .env when you run: streamlit run main.py

# Required: Groq API key from https://console.groq.com/
GROQ_API_KEY=

# Optional: Docker image used for sandboxed Manim rendering (default shown)
# MANIM_SANDBOX_IMAGE=manimcommunity/manim:v0.17.3

# Optional: Max seconds for a single sandbox render (default: 120)
# MANIM_SANDBOX_TIMEOUT=120

# Optional: Only if your Docker/Podman client needs non-default connection settings.
# The app passes these through to the container CLI when present:
# DOCKER_HOST=
# DOCKER_CONTEXT=
# DOCKER_TLS_VERIFY=
# DOCKER_CERT_PATH=
